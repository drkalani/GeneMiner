# Backend environment variables.
# Copy this file to .env and edit values as needed.

# Optional Hugging Face auth token to avoid rate limits during model download.
HF_TOKEN=

# Optional Hugging Face cache locations.
HF_HOME=$HOME/.cache/huggingface
HF_HUB_CACHE=$HOME/.cache/huggingface/hub
HUGGINGFACE_HUB_CACHE=$HOME/.cache/huggingface/hub

# Optional Bent microservice URL (leave empty for fallback behavior).
# Examples:
# - local microservice: http://127.0.0.1:8010
# - compose service: http://bent-runtime:8010
BENT_SERVICE_URL=

# Optional Bent request timeout (seconds).
BENT_SERVICE_TIMEOUT_SECONDS=30
